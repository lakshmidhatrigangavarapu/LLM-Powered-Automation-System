# ==========================================
# 🌐 Environment Variables Example for GitHub Sequential Agent
# Copy this content to .env and replace placeholder values
# ==========================================

# --- GitHub Configuration ---
GITHUB_PAT=your_github_pat_here
GITHUB_API_URL=https://api.github.com
GITHUB_URL=https://github.com
GITHUB_AUTH_SCHEME=bearer

# --- Gemini Flash Configuration ---
API_KEY=your_internal_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- LLM Configuration ---
LLM_PROVIDER=gemini_flash
LLM_TIMEOUT=300

# --- MCP Server Configuration ---
# GitHub MCP (HTTP-based)
MCP_HTTP_URL=http://localhost:9001/sse

# Sequential MCP (stdio-based)
SEQUENTIAL_MCP_COMMAND=uv
SEQUENTIAL_MCP_ARGS=run -m mcp_sequential_thinking.server
SEQUENTIAL_MCP_PATH=/path/to/github_agent_sequential/servers/mcp-sequential-thinking-master

# --- Flask Server Configuration ---
FLASK_PORT=5001

# --- Logging Configuration ---
LOG_FILE=server.logs
LOG_LEVEL=INFO

# --- Sensitive Actions ---
# Actions that require confirmation before execution
SENSITIVE_ACTIONS=create_issue,create_pull_request
ENABLE_CONFIRMATION_SHA=True
CONFIRMATION_SALT=github_seq_salt_123
